generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())
}

model ScraperConfig {
  id                Int      @id @default(1)
  keywords          String // JSON-encoded {label:string,enabled:boolean}[]
  locations         String // JSON-encoded {label:string,enabled:boolean}[]
  excludedCompanies String   @default("[]") // JSON-encoded String[]
  jobTypes          String   @default("[\"F\",\"C\"]") // JSON-encoded String[] — F,C,P,T,I,V
  workplaceTypes    String   @default("[\"1\",\"2\",\"3\"]") // JSON-encoded String[] — 1=onsite,2=remote,3=hybrid
  timeRange         String   @default("r86400") // LinkedIn f_TPR: r3600,r86400,r604800,r2592000
  updatedAt         DateTime @updatedAt
}

// Singleton row id=1: manual run progress for admin UI
model ScraperRunState {
  id           Int       @id @default(1)
  running      Boolean   @default(false)
  pid          Int?
  startedAt    DateTime?
  finishedAt   DateTime?
  lastExitCode Int?
  lastError    String?
}

model CvProfile {
  id        String   @id @default(cuid())
  name      String   @unique
  fileName  String
  fileData  String // base64 HTML (used for CV tailoring pipeline)
  mimeType  String
  pdfName   String? // original uploaded PDF filename
  pdfData   String? // base64 encoded source PDF
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Singleton (id=1): the HTML CV used as style/layout reference for PDF-to-HTML conversion
model SampleCv {
  id        Int      @id @default(1)
  fileName  String
  fileData  String // base64 HTML
  mimeType  String   @default("text/html")
  updatedAt DateTime @updatedAt
}

model Job {
  id             String    @id @default(cuid())
  linkedinId     String?   @unique
  link           String    @unique
  title          String
  company        String
  location       String?
  postedAt       DateTime?
  searchKeyword  String?
  searchLocation String?
  scrapedAt      DateTime?
  status         String    @default("NEW")
  description    String?
  notes          String?
  cvHtml         String?
  attachmentName String?
  attachmentData String?
  attachmentType String?
  importMethod   String    @default("scraped") // scraped | manual
  tags           String    @default("[]") // JSON-encoded String[] (normalized lowercase)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}
