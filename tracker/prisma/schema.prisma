generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())
}

model ScraperConfig {
  id                Int      @id @default(1)
  keywords          String // JSON-encoded String[]
  locations         String // JSON-encoded String[]
  excludedCompanies String   @default("[]") // JSON-encoded String[]
  updatedAt         DateTime @updatedAt
}

// Singleton row id=1: manual run progress for admin UI
model ScraperRunState {
  id           Int       @id @default(1)
  running      Boolean   @default(false)
  startedAt    DateTime?
  finishedAt   DateTime?
  lastExitCode Int?
  lastError    String?
}

model CvProfile {
  id        String   @id @default(cuid())
  name      String   @unique
  fileName  String
  fileData  String // base64
  mimeType  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Job {
  id             String    @id @default(cuid())
  linkedinId     String?   @unique
  link           String    @unique
  title          String
  company        String
  location       String?
  postedAt       DateTime?
  searchKeyword  String?
  searchLocation String?
  scrapedAt      DateTime?
  status         String    @default("NEW")
  description    String?
  notes          String?
  cvHtml         String?
  attachmentName String?
  attachmentData String?
  attachmentType String?
  importMethod   String    @default("scraped") // scraped | manual
  tags           String    @default("[]") // JSON-encoded String[] (normalized lowercase)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}
