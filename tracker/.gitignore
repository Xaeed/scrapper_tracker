#######################################
# n8n (VERY IMPORTANT)
#######################################

# Local n8n data (SQLite DB, credentials, workflows)
.n8n/
n8n_data/

# If you export workflows manually
*.n8n.json

# Credentials (never commit)
credentials.json

#######################################
# Docker
#######################################

# Docker volumes / local mounts
docker-data/
n8n-files/
files/

# Docker override / local configs
docker-compose.override.yml

# Ignore local-only envs but keep template
.env.local
.env.docker

#######################################
# Optional: allow sample configs
#######################################
!.env.example
!.docker-compose.yml

